generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Presupuestos del flujo completo (6 pasos)
model Quote {
  id                    String    @id @default(cuid())
  clientIp              String
  timestamp             DateTime  @default(now())
  language              String    @default("es")
  
  // Paso 1: Servicio
  tipoServicio          String    // "sustitución" | "instalacion"
  
  // Paso 2: Tipo Equipo
  tipoEquipo            String    // "split", "multisplit", "conducto", etc.
  
  // Paso 3: Características del espacio
  metrosCuadrados       Int
  altura                Float
  exposicionSolar       Float     @default(1.0)
  frigoriasCalculadas   Int
  
  // Paso 4: Modelo Seleccionado
  modeloSeleccionado    String
  marcaSeleccionada     String
  precioEquipo          Float
  
  // Paso 5: Extras
  andamio               Boolean   @default(false)
  andamioPrice          Float     @default(0)
  urgencia72h           Boolean   @default(false)
  urgenciaPrice         Float     @default(0)
  metrosAdicionales     Int       @default(0)
  metrosAdicionalesPrice Float    @default(0)
  
  // Paso 6: Presupuesto Final
  subtotal              Float
  iva                   Float
  descuentoPorcentaje   Float     @default(0)
  descuentoMonto        Float     @default(0)
  totalFinal            Float
  ofertaTemporal        Boolean   @default(true)
  
  // Datos del cliente
  nombreCliente         String?
  emailCliente          String?
  telefonoCliente       String?
  direccionCliente      String?
  codigoPostalCliente   String?
  
  // Estado
  completado            Boolean   @default(false)
  
  @@index([clientIp])
}

// Descuentos por IP (para oferta temporal de 5 minutos)
model DiscountByIP {
  id                    String    @id @default(cuid())
  clientIp              String    @unique
  ultimoDescuentoUsado  DateTime?
  
  @@index([clientIp])
}

// Contactos del flujo B (Servicios Rápidos)
model Contact {
  id                    String    @id @default(cuid())
  tipoServicio          String    // "averias" | "proyecto"
  nombre                String
  email                 String
  telefono              String
  descripcion           String    @db.Text
  timestamp             DateTime  @default(now())
  estado                String    @default("nuevo") // "nuevo", "procesado", "respondido"
  
  @@index([timestamp])
}

// Configuración de temporadas y tarifas
model SeasonConfig {
  id                    String    @id @default(cuid())
  temporadaAltaInicio   String    // "15/05"
  temporadaAltaFin      String    // "15/09"
  precioUrgenciaAlta    Float
  precioUrgenciaBaja    Float
  precioAveriaAlta      Float
  precioAveriaBaja      Float
  
  @@unique([temporadaAltaInicio, temporadaAltaFin])
}

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Quote {
    id                    Int      @id @default(autoincrement())
    clientIp              String
    tipoServicio          String
    tipoEquipo            String
    metrosCuadrados       Float
    alturaTecho           Float
    exposicionSolar       String
    frigoriasCalculadas   Int
    modeloSeleccionado    String
    marcaSeleccionada     String
    precioEquipo          Float
    precioInstalacion     Float
    andamio               Boolean  @default(false)
    urgente               Boolean  @default(false)
    metrosExtra           Int      @default(0)
    descuento             Float    @default(0)
    totalSinIva           Float
    iva                   Float
    totalFinal            Float
    completado            Boolean  @default(false)
    timestamp             DateTime @default(now())

    nombreCliente         String?
    telefonoCliente       String?
    cpCliente             String?
    direccionCliente      String?
    emailCliente          String?
    estancia              String?
    conductoUnidadesInteriores Int?
    precioConducto        Float?

    @@index([clientIp])
    @@index([timestamp])
}

model DiscountByIP {
    id                    Int      @id @default(autoincrement())
    clientIp              String   @unique
    ultimoDescuentoUsado  DateTime @default(now())

    @@index([clientIp])
}

model Contact {
    id              Int      @id @default(autoincrement())
    tipoServicio    String
    nombre          String
    email           String
    telefono        String
    descripcion     String?
    estado          String   @default("pendiente")
    timestamp       DateTime @default(now())

    @@index([timestamp])
}

model SeasonConfig {
    id                    Int    @id @default(autoincrement())
    temporadaAltaInicio   String
    temporadaAltaFin      String
    precioUrgenciaAlta    Float  @default(250)
    precioUrgenciaBaja    Float  @default(150)
    precioAveriaAlta      Float  @default(120)
    precioAveriaBaja      Float  @default(90)

    @@unique([temporadaAltaInicio, temporadaAltaFin])
}
